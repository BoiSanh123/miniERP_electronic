{
  "name": "mini-erp",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "npm run dev -w @mini-erp/backend",
    "dev:fe": "npm run dev -w @mini-erp/frontend",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:fe\"",
    "build": "npm run build -w @mini-erp/backend",
    "build:fe": "npm run build -w @mini-erp/frontend",
    "lint": "npm run lint -w @mini-erp/backend",
    "test": "npm run test -w @mini-erp/backend",
    "db:migrate": "npm run db:migrate -w @mini-erp/backend",
    "db:generate": "npm run db:generate -w @mini-erp/backend",
    "db:seed": "npm run db:seed -w @mini-erp/backend",
    "infra:up": "docker compose --env-file backend/.env up -d --wait",
    "infra:down": "docker compose --env-file backend/.env down",
    "infra:logs": "docker compose --env-file backend/.env logs -f",
    "infra:reset": "docker compose --env-file backend/.env down -v && docker compose --env-file backend/.env up -d --wait",
    "infra:fresh": "npm run infra:reset && npm run db:migrate && npm run db:seed",
    "setup": "npm install && npm run infra:up && npm run db:migrate && npm run db:seed"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  },
  "engines": {
    "node": ">=22"
  }
}
